# Configuración de Base de Datos
# Para MySQL (XAMPP local): mysql+pymysql://root:@localhost/fungivalle_db
# Para Supabase (PostgreSQL): postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Seguridad
SECRET_KEY=tu_clave_secreta_super_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Configuración de Email (Opcional, para recuperación de contraseña)
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_password_de_aplicacion
MAIL_FROM=tu_email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# URL del Frontend (Para CORS si es necesario)
FRONTEND_URL=http://localhost:3000
